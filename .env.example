# Copy to .env for local runs. Never commit .env.

# Optional proxy for YouTube access, for example http://127.0.0.1:7890
YTDLP_PROXY=

# Optional OpenAI-compatible ASR/LLM provider key.
# Keep real keys in .env or your OS secret store only.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ASR_MODEL=whisper-1

# Optional local ASR command. Example:
# LOCAL_ASR_COMMAND=faster-whisper "{audio}" --model medium --output_dir "{out_dir}" --output_format srt
LOCAL_ASR_COMMAND=

# Optional voice model paths or external TTS service settings.
TTS_PROVIDER=
TTS_VOICE_MODEL_PATH=

